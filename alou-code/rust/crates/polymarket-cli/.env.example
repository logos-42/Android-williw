# Polymarket CLI Configuration
# Copy this file to .env and fill in your values

# Ethereum RPC URL (Polygon Mainnet for Polymarket)
RPC_URL=https://polygon-rpc.com

# Wallet Private Key (optional - for trading)
# WARNING: Never commit your private key to version control!
PRIVATE_KEY=

# Wallet Mnemonic (optional - alternative to private key)
MNEMONIC=

# Polymarket Contract Addresses
POLYMARKET_CONDITIONAL_TOKENS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
POLYMARKET_COLLATERAL_TOKEN=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174  # USDC on Polygon

# API Configuration
POLYMARKET_API_BASE=https://gamma-api.polymarket.com

# Trading Configuration
DEFAULT_SLIPPAGE=0.01  # 1%
DEFAULT_GAS_LIMIT=300000
DEFAULT_GAS_PRICE=50  # gwei

# Bot Configuration
MARKET_MAKER_SPREAD=0.01  # 1%
MARKET_MAKER_SIZE=100.0
ARBITRAGE_THRESHOLD=0.01  # 1%
TREND_STOP_LOSS=0.05  # 5%
TREND_TAKE_PROFIT=0.10  # 10%

# Monitoring Configuration
MONITOR_INTERVAL=60  # seconds
PRICE_ALERT_THRESHOLD=0.05  # 5%