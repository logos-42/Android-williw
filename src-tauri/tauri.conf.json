{
  "productName": "Williw",
  "version": "0.1.0",
  "identifier": "com.williw.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "cd ../frontend && cargo build --target wasm32-unknown-unknown",
    "beforeBuildCommand": "cd ../frontend && cargo build --release --target wasm32-unknown-unknown",
    "devUrl": "http://localhost:1430",
    "withGlobalTauri": false
  },
  "app": {
    "windows": [
      {
        "title": "Williw - AI Compute Power",
        "width": 900,
        "height": 600,
        "minWidth": 320,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "apk"
    ],
    "identifier": "com.williw.app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
