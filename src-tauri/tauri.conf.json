{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Williw",
  "version": "0.1.0",
  "identifier": "com.williw.app",
  "build": {
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Williw — Local AI on Your Phone",
        "width": 420,
        "height": 760,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local AI compute on your phone",
    "longDescription": "Williw runs a small language model locally on your Android device and exposes an OpenAI-compatible HTTP API on 127.0.0.1:8081."
  }
}
